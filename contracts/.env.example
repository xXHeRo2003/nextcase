# RPC URL for Polygon Amoy (e.g., from Alchemy or Infura)
RPC_URL=https://rpc-amoy.polygon.technology

# Private key of the deployer account (NEVER share this or commit it!)
PRIVATE_KEY=your_private_key_here

# Optional: Polygonscan API Key for contract verification
POLYGONSCAN_API_KEY=your_api_key_here

# Initial Protocol Fee Recipient
PROTOCOL_FEE_RECIPIENT=0x...your_address...
