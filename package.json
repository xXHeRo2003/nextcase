{
  "name": "nextcase",
  "version": "1.0.0",
  "description": "NextCase Monorepo",
  "private": true,
  "packageManager": "npm@11.13.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write .",
    "contracts:build": "npm run build --workspace=@nextcase/contracts",
    "contracts:test": "npm run test --workspace=@nextcase/contracts",
    "contracts:fmt": "npm run fmt --workspace=@nextcase/contracts"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.7"
  }
}
